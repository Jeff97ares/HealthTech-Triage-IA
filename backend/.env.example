# Cadena de conexión a PostgreSQL
# Formato: postgresql://usuario:password@host:puerto/nombre_bd
DATABASE_URL=postgresql://usuario:contraseña@127.0.0.1:5434/healthtech_triage

# Origen permitido para CORS (URL del frontend)
FRONTEND_URL=http://localhost:5174

# --- Clasificación asistida por IA ---
# El sistema funciona sin estas variables: si falta la clave del proveedor
# activo, o AI_ENABLED=false, se usa únicamente el motor de reglas (nunca
# deja el formulario inutilizable).

# Activa/desactiva la IA. Ponlo en false para usar solo el motor de reglas.
AI_ENABLED=true

# Proveedor a usar: "gemini" u "openai". Solo se necesita configurar la
# clave del proveedor elegido; el otro puede quedar vacío.
AI_PROVIDER=gemini

# --- Google Gemini ---
# Clave desde https://aistudio.google.com/apikey (plan gratuito disponible).
# NUNCA subas tu clave real a GitHub; este archivo es solo un ejemplo.
GEMINI_API_KEY=coloque_aqui_su_clave
GEMINI_MODEL=modelo_configurable

# --- OpenAI ---
# Clave desde https://platform.openai.com/api-keys (requiere facturación activa).
OPENAI_API_KEY=coloque_aqui_su_clave
OPENAI_MODEL=modelo_configurable

# Tiempo máximo de espera (segundos) para la respuesta del modelo.
AI_TIMEOUT_SECONDS=8
