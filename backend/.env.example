# Cadena de conexión a PostgreSQL
# Formato: postgresql://usuario:password@host:puerto/nombre_bd
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/healthtech_triage

# Origen permitido para CORS (URL del frontend)
FRONTEND_URL=http://localhost:5173

# Clave opcional para conectar una API de LLM en el futuro (no requerida para funcionar)
OPENAI_API_KEY=
